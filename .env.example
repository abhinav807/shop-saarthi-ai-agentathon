# Supabase Configuration (Required for full functionality)
# Get these from your Supabase project settings > API
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_your-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"  # Only for server-side admin operations

# Client-side variables (VITE_ prefix makes them available in browser)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your-key-here"

# AI Gateway (Optional - for AI Coach and Daily Planner features)
# Get this from Lovable's AI Gateway settings
LOVABLE_API_KEY="your-lovable-api-key-here"
